<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Mission Type" Width="300" Height="150">
    <StackPanel Margin="10">
        <TextBlock Text="Choose mission type:" Margin="0,0,0,10"/>
        <ComboBox x:Name="TypeCombo" SelectedIndex="0">
            <ComboBoxItem>Orbital</ComboBoxItem>
            <ComboBoxItem>Planetary</ComboBoxItem>
        </ComboBox>
        <Button Content="OK" Click="OkClick" Margin="0,10,0,0"/>
    </StackPanel>
</Window>
