<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SpaceMission.Views.MissionEditWindow"
        Title="Edit Mission" Width="500" Height="550">
    <StackPanel Margin="10">
        <CheckBox Content="Dev Mode (прямое редактирование)" 
          IsChecked="{Binding IsDevMode}" 
          Margin="0,0,0,10"
          IsVisible="{Binding IsModeSwitchVisible}"/>

        <!-- Обычный режим (не DevMode) -->
        <StackPanel IsVisible="{Binding IsNormalMode}">
            <TextBlock Text="Name:"/>
            <TextBlock Text="{Binding ReadOnlyName}" Margin="0,0,0,5"/>
            <TextBlock Text="Budget:"/>
            <TextBlock Text="{Binding ReadOnlyBudget}" Margin="0,0,0,5"/>
            <TextBlock Text="Duration (days):"/>
            <TextBlock Text="{Binding ReadOnlyDuration}" Margin="0,0,0,10"/>

            <TextBlock Text="Extend mission by (days):" FontWeight="Bold" Margin="0,10,0,5"/>
            <TextBox Text="{Binding ExtendDays}" Width="100"/>
            <Button Command="{Binding ExtendMissionCommand}" Content="Extend" Margin="0,5,0,15"/>

            <StackPanel IsVisible="{Binding IsOrbital}">
                <TextBlock Text="Change orbit by (km):" FontWeight="Bold"/>
                <TextBox Text="{Binding OrbitDelta}" Width="100"/>
                <Button Command="{Binding ChangeOrbitCommand}" Content="Change Orbit" Margin="0,5"/>

                <TextBlock Text="Set target height (km):" FontWeight="Bold"/>
                <TextBox Text="{Binding NewTargetHeight}" Width="100"/>
                <Button Command="{Binding SetTargetHeightCommand}" Content="Set Target Height" Margin="0,5,0,15"/>
            </StackPanel>

            <StackPanel IsVisible="{Binding IsPlanetary}">
                <TextBlock Text="Set landing point:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Watermark="Name" Text="{Binding NewLandingName}" Width="150" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <StackPanel>
                        <TextBlock Text="X" FontSize="12"/>
                        <TextBox Watermark="X" Text="{Binding NewLandingX}" Width="80"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Y" FontSize="12"/>
                        <TextBox Watermark="Y" Text="{Binding NewLandingY}" Width="80"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="R" FontSize="12"/>
                        <TextBox Watermark="R" Text="{Binding NewLandingR}" Width="80"/>
                    </StackPanel>
                </StackPanel>

                <Button Command="{Binding SetLandingPointCommand}" Content="Set Landing Point" Margin="0,15,0,15"/>
            </StackPanel>

        </StackPanel>

        <!-- Режим DevMode (прямое редактирование) -->
        <StackPanel IsVisible="{Binding IsDevMode}">
            <TextBlock Text="Name:"/>
            <TextBox Text="{Binding Name}"/>
            <TextBlock Text="Budget:"/>
            <TextBox Text="{Binding Budget}"/>
            <TextBlock Text="Duration (days):"/>
            <TextBox Text="{Binding Duration}"/>

            <StackPanel IsVisible="{Binding IsOrbital}">
                <TextBlock Text="Orbital Parameters" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBlock Text="Current Height (km):"/>
                <TextBox Text="{Binding CurrHeight}"/>
                <TextBlock Text="Target Height (km):"/>
                <TextBox Text="{Binding TargetHeight}"/>
                <TextBlock Text="Inclination (deg):"/>
                <TextBox Text="{Binding Inclination}"/>
                <TextBlock Text="Energy Source:"/>
                <ComboBox ItemsSource="{Binding EnergySources}" SelectedItem="{Binding EnergySource}"/>
            </StackPanel>

            <StackPanel IsVisible="{Binding IsPlanetary}">
                <TextBlock Text="Planetary Parameters" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBlock Text="Planet:"/>
                <TextBox Text="{Binding Planet}"/>
                <TextBlock Text="Atmo Density (0-255):"/>
                <TextBox Text="{Binding AtmoDensity}"/>
                <TextBlock Text="Landing Point Name:"/>
                <TextBox Text="{Binding LandingPointName}"/>
                <TextBlock Text="X:"/>
                <TextBox Text="{Binding LandingPointX}"/>
                <TextBlock Text="Y:"/>
                <TextBox Text="{Binding LandingPointY}"/>
                <TextBlock Text="R:"/>
                <TextBox Text="{Binding LandingPointR}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
            <Button Content="OK" Click="OkClick" Margin="0,0,10,0"/>
            <Button Content="Cancel" Click="CancelClick"/>
        </StackPanel>
    </StackPanel>
</Window>
