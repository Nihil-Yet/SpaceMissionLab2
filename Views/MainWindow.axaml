<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SpaceMission.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SpaceMission.Views.MainWindow"
        Title="Space Mission Manager">
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- меню -->
            <RowDefinition Height="*"/>     <!-- основное содержимое -->
        </Grid.RowDefinitions>

        <!-- Меню -->
        <Menu Grid.Row="0">
            <MenuItem Header="_Missions">
                <MenuItem Header="Add" Command="{Binding AddMissionCommand}" />
                <MenuItem Header="Edit" Command="{Binding EditMissionCommand}" />
                <MenuItem Header="Delete" Command="{Binding DeleteMissionCommand}" />
                <MenuItem Header="Details" Command="{Binding ShowDetailsCommand}" />
            </MenuItem>
        </Menu>

        <!-- Основная область: таблица + панель кнопок -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>      <!-- таблица -->
                <ColumnDefinition Width="Auto"/>   <!-- кнопки -->
            </Grid.ColumnDefinitions>

            <!-- Таблица: заголовки + список -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- заголовки -->
                    <RowDefinition Height="*"/>     <!-- список -->
                </Grid.RowDefinitions>

                <!-- Заголовки (те же колонки, что и в элементах списка) -->
                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ID" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Name" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="Type" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="Budget" FontWeight="Bold"/>
                    <TextBlock Grid.Column="4" Text="Duration" FontWeight="Bold"/>
                </Grid>

                <!-- Список миссий -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Missions}" SelectedItem="{Binding SelectedMission}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Id}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding MissionType}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Budget}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Duration}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Панель кнопок справа -->
            <StackPanel Grid.Column="1" Margin="10" Width="120">
                <Button Command="{Binding AddMissionCommand}" Content="Add" Margin="0,0,0,5"/>
                <Button Command="{Binding EditMissionCommand}" Content="Edit" Margin="0,0,0,5"/>
                <Button Command="{Binding DeleteMissionCommand}" Content="Delete" Margin="0,0,0,5"/>
                <Button Command="{Binding ShowDetailsCommand}" Content="Details" Margin="0,0,0,5"/>
                <Button Command="{Binding LoadMissionsCommand}" Content="Refresh" Margin="0,0,0,5"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
