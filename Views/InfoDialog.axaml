<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SpaceMission.Views.InfoDialog"
        Title="Подробности о миссии" Width="550" Height="500"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <!-- Панель с кнопками (слева) -->
        <StackPanel DockPanel.Dock="Left" Margin="10" Width="150">
            <Button Command="{Binding ShowGetInfoCommand}" Content="GetInfo" Margin="0,0,0,5"/>
            <Button Command="{Binding ShowCalcRiskCommand}" Content="CalcRisk" Margin="0,0,0,5"/>
            <Button Command="{Binding ShowCalcFuelCommand}" Content="CalcFuel" Margin="0,0,0,15"/>

            <StackPanel IsVisible="{Binding IsOrbital}">
                <Button Command="{Binding ShowOrbitStateCommand}" Content="OrbitState" Margin="0,0,0,15"/>
            </StackPanel>

            <StackPanel IsVisible="{Binding IsPlanetary}">
                <Button Command="{Binding ShowHasAtmosphereCommand}" Content="HasAtmosphere" Margin="0,0,0,5"/>
                <Button Command="{Binding ShowScientificGoalCommand}" Content="ScientificGoal" Margin="0,0,0,15"/>
            </StackPanel>

            <Button Content="Закрыть" Click="CloseClick" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Область вывода результата (справа) -->
        <Border Background="#F0F0F0" CornerRadius="8" Margin="10" Padding="10">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="Black"/>
                <Border Height="2" Background="Gray" Margin="0,0,0,10"/>
                <Border Background="White" CornerRadius="6" Padding="10">
                    <ScrollViewer>
                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontFamily="Courier New" Foreground="Black"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>
